  "keyFeatures": [
    "Pay by Bank (account-to-account EFT payments)",
    "Real-Time Clearing (RTC) payouts",
    "Automated refunds with partial/split support",
    "Ozow ME peer-to-peer payments via QR, SMS, and WhatsApp",
    "Pocket digital wallet with ATM withdrawals",
    "Capitec Pay integration",
    "OneAPI — unified REST API for all payment methods (Beta)",
    "OAuth 2.0 and idempotency support in OneAPI",
    "PCI DSS and ISO 27001 certified",
    "Merchant Dashboard for transaction management and float top-up",
    "Bank account CDV (Check Digit Verification)",
    "Webhook notifications for async transaction outcomes"
  ],
  "publicApiSurface": [
    "POST https://api.ozow.com/PostPaymentRequest",
    "GET  https://api.ozow.com/GetTransactionStatus",
    "POST https://api.ozow.com/PostRefundRequest",
    "POST https://one.ozow.com (OneAPI — unified payments endpoint)",
    "Refunds API — Authorization: Bearer token header",
    "Payouts API — submit single payout, check payout status",
    "Webhooks — transaction outcome notifications (complete, cancelled, expired)"
  ]
